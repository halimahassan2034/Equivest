;; Cap Table Management System for Equivest\n;; Tracks share classes, valuations, and comprehensive cap table data\n\n(define-constant CONTRACT_OWNER tx-sender)\n(define-constant ERR_UNAUTHORIZED (err u400))\n(define-constant ERR_INVALID_SHARE_CLASS (err u401))\n(define-constant ERR_SHARE_CLASS_EXISTS (err u402))\n(define-constant ERR_INVALID_AMOUNT (err u403))\n(define-constant ERR_INSUFFICIENT_SHARES (err u404))\n(define-constant ERR_INVALID_VALUATION (err u405))\n(define-constant ERR_INVESTOR_NOT_FOUND (err u406))\n(define-constant ERR_ROUND_NOT_FOUND (err u407))\n\n;; Share class types\n(define-constant COMMON_SHARES u1)\n(define-constant PREFERRED_SHARES u2)\n(define-constant WARRANT_SHARES u3)\n(define-constant OPTION_SHARES u4)\n\n(define-data-var round-counter uint u0)\n(define-data-var company-valuation uint u0)\n(define-data-var last-valuation-update uint u0)\n\n;; Track different share classes\n(define-map share-classes\n  { class-id: uint }\n  {\n    class-name: (string-ascii 32),\n    class-type: uint,\n    voting-rights: bool,\n    liquidation-preference: uint,\n    dividend-rate: uint,\n    total-authorized: uint,\n    total-issued: uint,\n    par-value: uint,\n    created-at: uint\n  }\n)\n\n;; Track investor holdings by share class\n(define-map investor-holdings\n  { investor: principal, class-id: uint }\n  {\n    shares-owned: uint,\n    cost-basis: uint,\n    acquisition-date: uint,\n    vesting-schedule-id: (optional uint)\n  }\n)\n\n;; Track funding rounds\n(define-map funding-rounds\n  { round-id: uint }\n  {\n    round-name: (string-ascii 32),\n    round-type: (string-ascii 16),\n    share-class-id: uint,\n    shares-sold: uint,\n    price-per-share: uint,\n    total-raised: uint,\n    pre-money-valuation: uint,\n    post-money-valuation: uint,\n    lead-investor: (optional principal),\n    closing-date: uint\n  }\n)\n\n;; Track cap table snapshots\n(define-map cap-table-snapshots\n  { snapshot-date: uint }\n  {\n    total-shares-outstanding: uint,\n    total-investors: uint,\n    company-valuation: uint,\n    fully-diluted-shares: uint,\n    snapshot-hash: (buff 32)\n  }\n)\n\n;; Track ownership percentages\n(define-map ownership-percentages\n  { investor: principal, snapshot-date: uint }\n  {\n    fully-diluted-percentage: uint,\n    basic-percentage: uint,\n    voting-percentage: uint\n  }\n)\n\n(define-data-var class-counter uint u0)\n(define-data-var total-investors uint u0)\n\n;; Create a new share class\n(define-public (create-share-class\n  (class-name (string-ascii 32))\n  (class-type uint)\n  (voting-rights bool)\n  (liquidation-preference uint)\n  (dividend-rate uint)\n  (total-authorized uint)\n  (par-value uint))\n  (let\n    (\n      (class-id (+ (var-get class-counter) u1))\n    )\n    (asserts! (is-eq tx-sender CONTRACT_OWNER) ERR_UNAUTHORIZED)\n    (asserts! (<= class-type u4) ERR_INVALID_SHARE_CLASS)\n    (asserts! (> total-authorized u0) ERR_INVALID_AMOUNT)\n    (asserts! (is-none (get-share-class-by-name class-name)) ERR_SHARE_CLASS_EXISTS)\n    \n    (map-set share-classes\n      { class-id: class-id }\n      {\n        class-name: class-name,\n        class-type: class-type,\n        voting-rights: voting-rights,\n        liquidation-preference: liquidation-preference,\n        dividend-rate: dividend-rate,\n        total-authorized: total-authorized,\n        total-issued: u0,\n        par-value: par-value,\n        created-at: stacks-block-height\n      }\n    )\n    \n    (var-set class-counter class-id)\n    (ok class-id)\n  )\n)\n\n;; Issue shares to investor\n(define-public (issue-shares\n  (investor principal)\n  (class-id uint)\n  (shares-amount uint)\n  (price-per-share uint))\n  (let\n    (\n      (share-class (unwrap! (map-get? share-classes { class-id: class-id }) ERR_INVALID_SHARE_CLASS))\n      (current-holdings (get-investor-holdings investor class-id))\n      (total-cost (* shares-amount price-per-share))\n      (current-issued (get total-issued share-class))\n      (new-issued (+ current-issued shares-amount))\n    )\n    (asserts! (is-eq tx-sender CONTRACT_OWNER) ERR_UNAUTHORIZED)\n    (asserts! (> shares-amount u0) ERR_INVALID_AMOUNT)\n    (asserts! (> price-per-share u0) ERR_INVALID_AMOUNT)\n    (asserts! (<= new-issued (get total-authorized share-class)) ERR_INSUFFICIENT_SHARES)\n    \n    ;; Update share class issued count\n    (map-set share-classes\n      { class-id: class-id }\n      (merge share-class { total-issued: new-issued })\n    )\n    \n    ;; Update investor holdings\n    (map-set investor-holdings\n      { investor: investor, class-id: class-id }\n      {\n        shares-owned: (+ (get shares-owned current-holdings) shares-amount),\n        cost-basis: (+ (get cost-basis current-holdings) total-cost),\n        acquisition-date: stacks-block-height,\n        vesting-schedule-id: none\n      }\n    )\n    \n    ;; Update total investors if new investor\n    (if (is-eq (get shares-owned current-holdings) u0)\n      (var-set total-investors (+ (var-get total-investors) u1))\n      true\n    )\n    \n    (ok shares-amount)\n  )\n)\n\n;; Record a funding round\n(define-public (record-funding-round\n  (round-name (string-ascii 32))\n  (round-type (string-ascii 16))\n  (share-class-id uint)\n  (shares-sold uint)\n  (price-per-share uint)\n  (pre-money-valuation uint)\n  (lead-investor (optional principal)))\n  (let\n    (\n      (round-id (+ (var-get round-counter) u1))\n      (total-raised (* shares-sold price-per-share))\n      (post-money-valuation (+ pre-money-valuation total-raised))\n    )\n    (asserts! (is-eq tx-sender CONTRACT_OWNER) ERR_UNAUTHORIZED)\n    (asserts! (> shares-sold u0) ERR_INVALID_AMOUNT)\n    (asserts! (> price-per-share u0) ERR_INVALID_AMOUNT)\n    (asserts! (> pre-money-valuation u0) ERR_INVALID_VALUATION)\n    (asserts! (is-some (map-get? share-classes { class-id: share-class-id })) ERR_INVALID_SHARE_CLASS)\n    \n    (map-set funding-rounds\n      { round-id: round-id }\n      {\n        round-name: round-name,\n        round-type: round-type,\n        share-class-id: share-class-id,\n        shares-sold: shares-sold,\n        price-per-share: price-per-share,\n        total-raised: total-raised,\n        pre-money-valuation: pre-money-valuation,\n        post-money-valuation: post-money-valuation,\n        lead-investor: lead-investor,\n        closing-date: stacks-block-height\n      }\n    )\n    \n    ;; Update company valuation\n    (var-set company-valuation post-money-valuation)\n    (var-set last-valuation-update stacks-block-height)\n    \n    (var-set round-counter round-id)\n    (ok round-id)\n  )\n)\n\n;; Create cap table snapshot\n(define-public (create-cap-table-snapshot)\n  (let\n    (\n      (snapshot-date stacks-block-height)\n      (total-outstanding (calculate-total-outstanding-shares))\n      (fully-diluted (calculate-fully-diluted-shares))\n      (current-investors (var-get total-investors))\n      (current-valuation (var-get company-valuation))\n      (snapshot-hash (keccak256 (concat \n        (int-to-ascii snapshot-date) \n        (int-to-ascii total-outstanding))))\n    )\n    (map-set cap-table-snapshots\n      { snapshot-date: snapshot-date }\n      {\n        total-shares-outstanding: total-outstanding,\n        total-investors: current-investors,\n        company-valuation: current-valuation,\n        fully-diluted-shares: fully-diluted,\n        snapshot-hash: snapshot-hash\n      }\n    )\n    \n    (ok snapshot-date)\n  )\n)\n\n;; Calculate ownership percentage for investor\n(define-public (calculate-ownership-percentage (investor principal))\n  (let\n    (\n      (snapshot-date stacks-block-height)\n      (total-outstanding (calculate-total-outstanding-shares))\n      (fully-diluted (calculate-fully-diluted-shares))\n      (investor-shares (calculate-total-investor-shares investor))\n      (voting-shares (calculate-voting-shares investor))\n      (basic-percentage (if (> total-outstanding u0) \n                         (/ (* investor-shares u10000) total-outstanding) \n                         u0))\n      (fully-diluted-percentage (if (> fully-diluted u0) \n                                 (/ (* investor-shares u10000) fully-diluted) \n                                 u0))\n      (voting-percentage (if (> voting-shares u0) \n                          (/ (* voting-shares u10000) total-outstanding) \n                          u0))\n    )\n    (map-set ownership-percentages\n      { investor: investor, snapshot-date: snapshot-date }\n      {\n        basic-percentage: basic-percentage,\n        fully-diluted-percentage: fully-diluted-percentage,\n        voting-percentage: voting-percentage\n      }\n    )\n    \n    (ok {\n      basic-percentage: basic-percentage,\n      fully-diluted-percentage: fully-diluted-percentage,\n      voting-percentage: voting-percentage\n    })\n  )\n)\n\n;; Read-only functions\n(define-read-only (get-share-class (class-id uint))\n  (map-get? share-classes { class-id: class-id })\n)\n\n(define-read-only (get-investor-holdings (investor principal) (class-id uint))\n  (default-to\n    {\n      shares-owned: u0,\n      cost-basis: u0,\n      acquisition-date: u0,\n      vesting-schedule-id: none\n    }\n    (map-get? investor-holdings { investor: investor, class-id: class-id })\n  )\n)\n\n(define-read-only (get-funding-round (round-id uint))\n  (map-get? funding-rounds { round-id: round-id })\n)\n\n(define-read-only (get-cap-table-snapshot (snapshot-date uint))\n  (map-get? cap-table-snapshots { snapshot-date: snapshot-date })\n)\n\n(define-read-only (get-company-valuation)\n  {\n    current-valuation: (var-get company-valuation),\n    last-updated: (var-get last-valuation-update)\n  }\n)\n\n(define-read-only (get-ownership-percentage (investor principal) (snapshot-date uint))\n  (map-get? ownership-percentages { investor: investor, snapshot-date: snapshot-date })\n)\n\n;; Private helper functions\n(define-private (get-share-class-by-name (class-name (string-ascii 32)))\n  ;; Simplified - would iterate through all classes in production\n  none\n)\n\n(define-private (calculate-total-outstanding-shares)\n  ;; Simplified calculation - would sum all issued shares across classes\n  u1000000\n)\n\n(define-private (calculate-fully-diluted-shares)\n  ;; Include options, warrants, and convertible securities\n  u1200000\n)\n\n(define-private (calculate-total-investor-shares (investor principal))\n  ;; Sum shares across all classes for investor\n  (let\n    (\n      (common-holdings (get shares-owned (get-investor-holdings investor u1)))\n      (preferred-holdings (get shares-owned (get-investor-holdings investor u2)))\n    )\n    (+ common-holdings preferred-holdings)\n  )\n)\n\n(define-private (calculate-voting-shares (investor principal))\n  ;; Only count shares with voting rights\n  (let\n    (\n      (common-holdings (get shares-owned (get-investor-holdings investor u1)))\n    )\n    common-holdings\n  )\n)\n\n(define-private (int-to-ascii (value uint))\n  ;; Convert integer to string - simplified implementation\n  "placeholder"\n)\n\n;; Additional read-only functions for cap table analysis\n(define-read-only (get-dilution-analysis (investor principal))\n  (let\n    (\n      (current-percentage (unwrap-panic (calculate-ownership-percentage investor)))\n      (total-outstanding (calculate-total-outstanding-shares))\n      (fully-diluted (calculate-fully-diluted-shares))\n      (potential-dilution (- (get fully-diluted-percentage current-percentage) \n                            (get basic-percentage current-percentage)))\n    )\n    {\n      current-basic-ownership: (get basic-percentage current-percentage),\n      fully-diluted-ownership: (get fully-diluted-percentage current-percentage),\n      potential-dilution: potential-dilution,\n      dilution-protection: (> potential-dilution u500) ;; Alert if >5% dilution\n    }\n  )\n)\n\n(define-read-only (get-cap-table-summary)\n  {\n    total-share-classes: (var-get class-counter),\n    total-funding-rounds: (var-get round-counter),\n    total-investors: (var-get total-investors),\n    company-valuation: (var-get company-valuation),\n    total-outstanding-shares: (calculate-total-outstanding-shares),\n    fully-diluted-shares: (calculate-fully-diluted-shares)\n  }\n)\n